# PostgreSQL connection string (provided by Railway automatically)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Secret key for signing JWTs — generate a long random string
# You can generate one with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Node environment
NODE_ENV=production

# Port (Railway sets this automatically — don't change)
PORT=3000

# --- EMAIL (optional but recommended) ---
# Sign up free at https://resend.com to get an API key
# Free tier: 100 emails/day, 3,000/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The "from" address for notification emails
# Free tier: use "onboarding@resend.dev" OR verify your own domain
FROM_EMAIL=PO System <onboarding@resend.dev>

# --- DOCUMENT VAULT STORAGE (Cloudflare R2) ---
# Create a free R2 bucket at https://dash.cloudflare.com (R2 > Create bucket),
# then create an R2 API token (R2 > Manage R2 API Tokens > Create, Object Read & Write).
# R2_ACCOUNT_ID is the long ID in your R2 endpoint URL on the R2 overview page.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=nova-documents

# --- PTT RADIO (LiveKit) ---
# Create a free project at https://cloud.livekit.io, then copy the values
# from Settings > Keys. URL looks like wss://your-project-xxxxxxx.livekit.cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=your-livekit-api-secret

# --- OUTLOOK ADD-IN SSO (passwordless "Send to Nova" sign-in) ---
# Register an app in Entra/Azure AD, expose an API with App ID URI
# api://www.popalockar.com/<client-id> and a scope "access_as_user", then:
ADDIN_SSO_CLIENT_ID=your-entra-app-client-id
# Optional overrides (sensible defaults are derived if omitted):
# ADDIN_SSO_APP_ID_URI defaults to api://www.popalockar.com/<ADDIN_SSO_CLIENT_ID>
ADDIN_SSO_APP_ID_URI=api://www.popalockar.com/your-entra-app-client-id
# ADDIN_SSO_TENANT_ID pins the tenant; if omitted, the tenant from the token is used.
ADDIN_SSO_TENANT_ID=your-azure-tenant-id

# --- NOVA VOICE (Hey Nova) ---
# ONE vendor powers both ears and voice: ElevenLabs (STT via Scribe + TTS).
# Get a key at https://elevenlabs.io (Profile > API Keys).
ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Voice to speak in. Copy an ID from ElevenLabs > Voices (default is the "Rachel" preset).
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Optional TTS model override (default eleven_turbo_v2_5 for low latency)
ELEVENLABS_MODEL=eleven_turbo_v2_5
# Optional STT model override (default scribe_v2; scribe_v1 also valid)
ELEVENLABS_STT_MODEL=scribe_v2

# --- AI ASSISTANT (Nova AI / Neurolock) ---
# Anthropic API key — powers AI chat, agent actions, review matching, feedback triage, quiz gen.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# Optional per-user AI usage caps (number of calls). Omit both for no cap.
AI_DAILY_LIMIT=
AI_MONTHLY_LIMIT=

# --- PUBLIC APP URL ---
# Base URL of this deployment. Used to build links in emails/SMS and OAuth/MCP metadata.
APP_URL=https://your-app.up.railway.app

# --- SMS 2FA + late-clock-in texts (Twilio) ---
# From the Twilio console. FROM_NUMBER must be an SMS-capable number you own.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# --- WEB / DESKTOP PUSH (VAPID) ---
# Generate a key pair once with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
# Contact URI required by the push spec (mailto: or https:).
VAPID_SUBJECT=mailto:admin@popalockar.com

# --- SECURE HR DOCUMENTS (onboarding: SSN / DL / I-9 / W-4) ---
# 32-byte hex key for AES-256-GCM encryption of collected HR docs.
# Generate with:  openssl rand -hex 32   (do NOT rotate without re-encrypting existing docs)
HR_DOC_ENC_KEY=change-me-64-hex-characters

# --- WORK ORDERS (dispatcher email intake; dormant until enabled) ---
WORK_ORDERS_ENABLED=false
# Shared mailbox that receives work-order emails (read via Microsoft Graph, below).
WORK_ORDERS_MAILBOX=workorders@popalockar.com
# User id that owns system-generated work-order records.
WORK_ORDERS_SYSTEM_USER_ID=
# Days to retain closed work orders before cleanup.
WORK_ORDER_RETENTION_DAYS=365

# --- MICROSOFT 365 GRAPH (mailbox ingest: GEICO + Work Orders) ---
# Entra app registration with application Mail.Read (plus others as needed).
MS_TENANT_ID=your-azure-tenant-id
MS_CLIENT_ID=your-graph-app-client-id
MS_CLIENT_SECRET=your-graph-app-client-secret

# --- GEICO REPORTING ---
# Mailbox the GEICO assignment emails land in, and who receives the digest.
GEICO_MAILBOX=geico@popalockar.com
GEICO_REPORT_RECIPIENTS=ops@popalockar.com, manager@popalockar.com

# --- REVIEWS DASHBOARD (external google-review-bot Postgres, read-only) ---
REVIEWS_DATABASE_URL=postgresql://user:password@host:port/dbname
# Optional PEM CA cert so TLS to that DB is fully verified. If omitted the connection
# still uses TLS but does not verify the server cert (encryption-only).
REVIEWS_DB_CA_CERT=

# --- INBOUND EMAIL WEBHOOKS (Resend) ---
# Shared secret Resend signs the email-to-task inbound webhook with.
RESEND_INBOUND_SECRET=your-inbound-webhook-secret
# Customer-feedback intake (Pulsar tech-conduct emails).
FEEDBACK_INBOUND_ADDRESS=feedback@in.popalockar.com
RESEND_FEEDBACK_SECRET=your-feedback-webhook-secret
# Optional model override for feedback classification (blank = default).
FEEDBACK_AI_MODEL=

# --- MISC ---
# Bearer key protecting the external report API endpoint.
REPORT_API_KEY=your-report-api-key
# Fallback payroll recipient if the in-app Company Info payroll email is blank.
PAYROLL_EMAIL=payroll@popalockar.com
# Days to retain audit-log rows before cleanup.
AUDIT_RETENTION_DAYS=730
